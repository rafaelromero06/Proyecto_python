def render_charts(theme):
    dark = (theme == "dark")
    df   = fetch_histoday("BTC", days=365)
 
    return _build_adf_visual(df, dark), _build_arima_visual(df, dark)
 
 
def _build_adf_visual(df, dark):
    """Muestra precios vs retornos para ilustrar estacionariedad."""
    if df.empty:
        return html.P("Sin datos.", className="mid")
 
    bg, pp, grid, txt, tdim = _tc(dark)
    fig = make_subplots(
        rows=2, cols=1, shared_xaxes=True,
        subplot_titles=["Precios (NO estacionario — media cambia)",
                        "Retornos (SÍ estacionario — media ≈ 0%)"],
        vertical_spacing=0.12,
    )
 
    fig.add_trace(go.Scatter(
        x=df["date"], y=df["close"], mode="lines",
        line=dict(color=_acc(dark), width=1.5), name="Precio",
    ), row=1, col=1)
 
    rets = df["close"].pct_change().dropna() * 100
    fig.add_trace(go.Bar(
        x=df["date"].iloc[1:], y=rets.values,
        marker_color=[_up(dark) if r >= 0 else _dn(dark) for r in rets],
        marker_line_width=0, opacity=0.7, name="Retorno %",
    ), row=2, col=1)
    fig.add_hline(y=0, line_dash="dot", line_color=tdim,
                  line_width=1, row=2, col=1)
 
    fig.update_layout(
        height=360, paper_bgcolor=pp, plot_bgcolor=bg,
        font=dict(family=MONO, color=txt, size=9),
        title=dict(text="Precios vs Retornos — BTC 1 año",
                   font=dict(color=txt, size=11)),
        margin=dict(t=48, b=20, l=52, r=16),
        showlegend=False,
    )
    for r in [1, 2]:
        fig.update_xaxes(row=r, gridcolor=grid, zeroline=False,
                         linecolor=grid, tickfont=dict(color=tdim, size=8))
        fig.update_yaxes(row=r, gridcolor=grid, zeroline=False,
                         linecolor=grid, tickfont=dict(color=tdim, size=8))
    fig.update_yaxes(row=1, tickprefix="$", tickformat=",")
    fig.update_yaxes(row=2, ticksuffix="%")
    for ann in fig.layout.annotations:
        ann.font.color = tdim
        ann.font.size  = 9
 
    return dcc.Graph(figure=fig, config={"displayModeBar": False},
                     className="gw")
 
 
def _build_arima_visual(df, dark):
    """Ajusta ARIMA y muestra pronóstico con IC como visualización ilustrativa."""
    if df.empty or len(df) < 60:
        return html.P("Sin datos suficientes.", className="mid")
 
    bg, pp, grid, txt, tdim = _tc(dark)
 
    try:
        import warnings
        warnings.filterwarnings("ignore")
        from statsmodels.tsa.arima.model import ARIMA as _ARIMA
 
        serie     = df.set_index("date")["close"].replace(0, None).dropna()
        val_size  = 30
        train_s   = serie.iloc[:-val_size]
        val_s     = serie.iloc[-val_size:]
 
        fitted   = _ARIMA(train_s, order=(2, 1, 2)).fit()
        val_fc   = fitted.forecast(steps=val_size)
        fc       = fitted.get_forecast(steps=14)
        fc_mean  = fc.predicted_mean
        ci95     = fc.conf_int(alpha=0.05)
        ci80     = fc.conf_int(alpha=0.20)
        fc_dates = pd.date_range(
            serie.index[-1] + pd.Timedelta(days=1), periods=14, freq="D"
        )
 
        mae   = float(np.mean(np.abs(val_fc.values - val_s.values)))
        mape  = float(np.mean(
            np.abs((val_fc.values - val_s.values) /
                   np.clip(np.abs(val_s.values), 1e-9, None))) * 100)
        cambio = (float(fc_mean.iloc[-1]) / float(serie.iloc[-1]) - 1) * 100
        fc_col = _up(dark) if cambio >= 0 else _dn(dark)
 
    except Exception:
        return html.P("No se pudo ajustar el modelo para la visualización.",
                      className="mid")
 
    fig = go.Figure()
    n_show = min(120, len(train_s))
 
    fig.add_trace(go.Scatter(
        x=train_s.index[-n_show:], y=train_s.values[-n_show:],
        mode="lines", name="Histórico",
        line=dict(color=tdim, width=1.2),
    ))
    fig.add_trace(go.Scatter(
        x=val_s.index, y=val_s.values,
        mode="lines", name="Real (validación)",
        line=dict(color=txt, width=1.5),
    ))
    fig.add_trace(go.Scatter(
        x=val_s.index, y=val_fc.values,
        mode="lines", name="ARIMA (validación)",
        line=dict(color=_acc(dark), width=1.5, dash="dot"),
    ))
    fig.add_trace(go.Scatter(
        x=list(fc_dates) + list(reversed(fc_dates)),
        y=list(ci95.iloc[:, 1]) + list(reversed(ci95.iloc[:, 0])),
        fill="toself", fillcolor=_acc(dark).replace(")", ",0.10)").replace("rgb", "rgba"),
        line=dict(color="rgba(0,0,0,0)"),
        name="IC 95%", hoverinfo="skip",
    ))
    fig.add_trace(go.Scatter(
        x=list(fc_dates) + list(reversed(fc_dates)),
        y=list(ci80.iloc[:, 1]) + list(reversed(ci80.iloc[:, 0])),
        fill="toself", fillcolor=_acc(dark).replace(")", ",0.20)").replace("rgb", "rgba"),
        line=dict(color="rgba(0,0,0,0)"),
        name="IC 80%", hoverinfo="skip",
    ))
    fig.add_trace(go.Scatter(
        x=fc_dates, y=fc_mean.values,
        mode="lines+markers", name="Pronóstico 14d",
        line=dict(color=fc_col, width=2),
        marker=dict(size=4, color=fc_col),
    ))
    fig.add_vline(x=str(fc_dates[0]), line_dash="dot",
                  line_color=tdim, line_width=1)
 
    fig.update_layout(
        height=400, paper_bgcolor=pp, plot_bgcolor=bg,
        font=dict(family=MONO, color=txt, size=9),
        title=dict(
